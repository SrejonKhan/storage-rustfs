# S3-compatible (RustFS) — copy to .env
S3_ENDPOINT=http://your-server-ip:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=your-secret-key
S3_BUCKET=test-uploads
S3_REGION=us-east-1
# URL shown after upload (path-style). Use your public URL if behind proxy.
S3_PUBLIC_URL=http://your-server-ip:9000

# Server
PORT=3000
